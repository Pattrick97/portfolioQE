{
  "name": "portfolioqe",
  "version": "1.0.0",
  "description": "This repository is showcasing my skills as a Quality Engineer",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke --project=chromium",
    "test:regression": "npx playwright test",
    "test:api": "npx playwright test --project=api",
    "test:api:smoke": "npx playwright test --project=api --grep @smoke",
    "perf:api:k6": "k6 run perf/k6/api-baseline.js",
    "perf:api:k6:smoke": "k6 run --vus 3 --duration 15s perf/k6/api-baseline.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pattrick97/portfolioQE.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Pattrick97/portfolioQE/issues"
  },
  "homepage": "https://github.com/Pattrick97/portfolioQE#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0"
  }
